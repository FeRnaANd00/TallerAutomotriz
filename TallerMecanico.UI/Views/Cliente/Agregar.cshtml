@model TallerMecanico.EN.Cliente

@{
    ViewData["Title"] = "Agregar Cliente";
}

<div class="container mt-4">
    <h2><i class="bi bi-person-plus text-warning"></i> Agregar Cliente</h2>

    <form method="post" asp-action="Agregar">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input type="text" name="Nombre" class="form-control" required maxlength="100" />
        </div>
        <div class="mb-3">
            <label class="form-label">Dirección</label>
            <input type="text" name="Direccion" class="form-control" maxlength="100" />
        </div>
        <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input type="text" name="Telefono" class="form-control" maxlength="15" />
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save"></i> Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
            <button type="button" class="btn btn-outline-secondary" onclick="history.back()">← Regresar</button>
        </div>
    </form>
</div>