@model TallerMecanico.EN.HojaDeParte

@{
    ViewData["Title"] = "Agregar Hoja de Parte";
}

<div class="container mt-4">
    <h2>Agregar Hoja de Parte</h2>

    <form method="post" asp-action="Agregar">
        <div class="mb-3">
            <label class="form-label">Concepto</label>
            <input type="text" name="Concepto" class="form-control" maxlength="200" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Cantidad</label>
            <input type="number" name="Cantidad" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Mecánico Responsable</label>
            <div class="input-group">
                <select name="Mecanico_Responsable_id" class="form-select">
                    <option value="">-- Sin asignar --</option>
                    @foreach (var item in (SelectList)ViewBag.Mecanicos)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
                <a asp-controller="Mecanico" asp-action="Agregar"
                   asp-route-returnUrl="@Url.Action("Agregar", "HojaDeParte")"
                   class="btn btn-outline-success" title="Agregar nuevo mecánico">
                    <i class="bi bi-person-plus-fill"></i> Nuevo
                </a>
            </div>
            <small class="text-muted">¿No está el mecánico? Agrégalo con el botón <strong>Nuevo</strong></small>
            </div>
            <div class="mb-3">
                <label class="form-label">Vehículo</label>
                <div class="input-group">
                    <select name="Vehiculo_id" class="form-select">
                        <option value="">-- Sin asignar --</option>
                        @foreach (var item in (SelectList)ViewBag.Vehiculos)
                        {
                            if (item.Selected)
                            {
                                <option value="@item.Value" selected>@item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                    <a asp-controller="Vehiculo" asp-action="Agregar"
                       asp-route-returnUrl="@Url.Action("Editar", "HojaDeParte")"
                       class="btn btn-outline-success">
                        <i class="bi bi-car-front"></i> Nuevo
                    </a>
                </div>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save"></i> Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>
                <button type="button" class="btn btn-outline-secondary" onclick="history.back()">← Regresar</button>
            </div>
    </form>
</div>