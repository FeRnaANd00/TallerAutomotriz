@model TallerMecanico.EN.HojaDeParte

@{
    ViewData["Title"] = "Agregar Hoja de Parte";
}

<div class="container mt-4">
    <h2>Agregar Hoja de Parte</h2>

    <form method="post" asp-action="Agregar">
        <div class="mb-3">
            <label class="form-label">Concepto</label>
            <input type="text" name="Concepto" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Cantidad</label>
            <input type="number" name="Cantidad" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Reparación</label>
            <input type="text" name="Reparacion" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Mecánico Responsable ID</label>
            <input type="number" name="Mecanico_Responsable_id" class="form-control" />
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-success">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>