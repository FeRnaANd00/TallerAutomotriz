@model TallerMecanico.EN.HojaDeParte

@{
    ViewData["Title"] = "Editar Hoja de Parte";
}

<div class="container mt-4">
    <h2>Editar Hoja de Parte</h2>

    <form method="post" asp-action="Editar">
        <input type="hidden" name="Id_hoja" value="@Model.Id_hoja" />
        <div class="mb-3">
            <label class="form-label">Concepto</label>
            <input type="text" name="Concepto" value="@Model.Concepto" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Cantidad</label>
            <input type="number" name="Cantidad" value="@Model.Cantidad" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Reparación</label>
            <input type="text" name="Reparacion" value="@Model.Reparacion" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Mecánico Responsable ID</label>
            <input type="number" name="Mecanico_Responsable_id" value="@Model.Mecanico_Responsable_id" class="form-control" />
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-warning">Guardar Cambios</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>