@model TallerMecanico.EN.HojaDeParte

<h2>Editar Hoja de Parte</h2>

<form asp-action="Editar" method="post">
    <input type="hidden" asp-for="Id_hoja" />

    <div class="mb-3">
        <label asp-for="Concepto" class="form-label">Concepto</label>
        <input asp-for="Concepto" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Cantidad" class="form-label">Cantidad</label>
        <input asp-for="Cantidad" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Reparacion" class="form-label">Reparación</label>
        <input asp-for="Reparacion" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Mecanico_Responsable_id" class="form-label">Mecánico Responsable</label>
        <!-- asp-items toma el SelectList del ViewBag -->
        <select asp-for="Mecanico_Responsable_id" asp-items="ViewBag.Mecanicos" class="form-select">
            <option value="">-- Seleccione un mecánico --</option>
        </select>
        <div class="input-group">
            <select name="Mecanico_Responsable_id" class="form-select">
                <option value="">-- Sin asignar --</option>
                @foreach (var item in (SelectList)ViewBag.Mecanicos)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
            <a asp-controller="Mecanico" asp-action="Agregar"
               asp-route-returnUrl="@Url.Action("Agregar", "HojaDeParte")"
               class="btn btn-outline-success" title="Agregar nuevo mecánico">
                <i class="bi bi-person-plus-fill"></i> Nuevo
            </a>
        </div>
        <small class="text-muted">¿No está el mecánico? Agrégalo con el botón <strong>Nuevo</strong></small>
    </div>
    </div>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div>
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
    <button type="button" class="btn btn-outline-secondary" onclick="history.back()">← Regresar</button>
</div>
</form>