@model TallerMecanico.EN.Repuesto

@{
    ViewData["Title"] = "Editar Repuesto";
}

<div class="container mt-4">
    <h2><i class="bi bi-pencil-square text-warning"></i> Editar Repuesto</h2>

    <form method="post" asp-action="Editar">
        <input type="hidden" asp-for="Id_repuesto" />

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <input asp-for="Descripcion" class="form-control" required maxlength="100" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Costo Unitario</label>
                <input asp-for="Costo_Uni" type="number" step="0.01" class="form-control" required min="0" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Precio Unitario (venta)</label>
                <input asp-for="Precio_Uni" type="number" step="0.01" class="form-control" required min="0" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Stock Actual</label>
            <input asp-for="Stock" type="number" class="form-control" required min="0" />
            <small class="text-muted">Ajusta manualmente si necesitas corregir el inventario.</small>
        </div>

        <input type="hidden" asp-for="Imp_parcial" />

        <div class="mt-3">
            <button type="submit" class="btn btn-warning">
                <i class="bi bi-save"></i> Guardar Cambios
            </button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>