@model TallerMecanico.EN.Repuesto

@{
    ViewData["Title"] = "Agregar Repuesto";
}

<div class="container mt-4">
    <h2><i class="bi bi-box-seam text-warning"></i> Agregar Repuesto</h2>

    <form method="post" asp-action="Agregar">
        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <input type="text" name="Descripcion" class="form-control" required maxlength="100" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Costo Unitario</label>
                <input type="number" step="0.01" name="Costo_Uni" class="form-control" required min="0" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Precio Unitario (venta)</label>
                <input type="number" step="0.01" name="Precio_Uni" class="form-control" required min="0" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Stock Inicial</label>
            <input type="number" name="Stock" class="form-control" required min="0" value="0" />
        </div>

        <input type="hidden" name="Imp_parcial" value="0" />

        <div class="mt-3">
            <button type="submit" class="btn btn-warning">
                <i class="bi bi-save"></i> Guardar
            </button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>