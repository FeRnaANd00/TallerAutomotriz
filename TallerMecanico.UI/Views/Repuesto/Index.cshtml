@model List<TallerMecanico.EN.Repuesto>

@{
    ViewData["Title"] = "Inventario de Repuestos";
}

<div class="container-fluid mt-4 px-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-box-seam text-warning"></i> Inventario de Repuestos
            </h2>
            <small class="text-muted">Gestión de repuestos y stock</small>
        </div>
        <a asp-action="Agregar" class="btn btn-warning">
            <i class="bi bi-plus-circle"></i> Nuevo Repuesto
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <form method="get" asp-action="Index">
                <div class="input-group">
                    <span class="input-group-text bg-warning border-0">
                        <i class="bi bi-search text-dark"></i>
                    </span>
                    <input type="text" name="buscar" value="@ViewBag.Buscar"
                           class="form-control border-0"
                           placeholder="Buscar repuesto..." />
                    <button class="btn btn-warning" type="submit">Buscar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Resumen rápido -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-check-circle text-success" style="font-size:1.8rem"></i>
                    <h5 class="mt-2">@Model.Count(r => r.Stock > 5)</h5>
                    <small class="text-muted">Stock OK</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-exclamation-triangle text-warning" style="font-size:1.8rem"></i>
                    <h5 class="mt-2">@Model.Count(r => r.Stock > 0 && r.Stock <= 5)</h5>
                    <small class="text-muted">Stock Bajo</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <i class="bi bi-x-circle text-danger" style="font-size:1.8rem"></i>
                    <h5 class="mt-2">@Model.Count(r => r.Stock == 0)</h5>
                    <small class="text-muted">Agotados</small>
                </div>
            </div>
        </div>
    </div>

    <p class="text-muted small mb-2">
        <i class="bi bi-list-ul"></i> @Model.Count repuesto(s) encontrado(s)
    </p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background-color: #212529; color: white;">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Descripción</th>
                        <th>Costo Unit.</th>
                        <th>Precio Unit.</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox" style="font-size:2rem"></i>
                                <p class="mt-2">No hay repuestos registrados</p>
                            </td>
                        </tr>
                    }
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-3 text-muted">#@r.Id_repuesto</td>
                            <td><span class="fw-semibold">@r.Descripcion</span></td>
                            <td>$@r.Costo_Uni.ToString("0.00")</td>
                            <td>$@r.Precio_Uni.ToString("0.00")</td>
                            <td><span class="badge bg-primary rounded-pill">@r.Stock</span></td>
                            <td>
                                @if (r.Stock == 0)
                                {
                                    <span class="badge bg-danger">Agotado</span>
                                }
                                else if (r.Stock <= 5)
                                {
                                    <span class="badge bg-warning text-dark">Stock Bajo</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">OK</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Editar" asp-route-id="@r.Id_repuesto"
                                   class="btn btn-warning btn-sm me-1">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <a asp-action="Eliminar" asp-route-id="@r.Id_repuesto"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('¿Desea eliminar este repuesto?')">
                                    <i class="bi bi-trash3"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>