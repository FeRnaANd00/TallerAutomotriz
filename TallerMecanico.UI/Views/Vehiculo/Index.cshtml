@model List<TallerMecanico.EN.Vehiculo>

@{
    ViewData["Title"] = "Vehículos";
}

<div class="container-fluid mt-4 px-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-car-front text-warning"></i> Vehículos
            </h2>
            <small class="text-muted">Gestión de vehículos del taller</small>
        </div>
        <a asp-action="Agregar" class="btn btn-warning">
            <i class="bi bi-plus-circle"></i> Nuevo Vehículo
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <form method="get" asp-action="Index">
                <div class="input-group">
                    <span class="input-group-text bg-warning border-0">
                        <i class="bi bi-search text-dark"></i>
                    </span>
                    <input type="text" name="buscar" value="@ViewBag.Buscar"
                           class="form-control border-0"
                           placeholder="Buscar por modelo, color o placa..." />
                    <button class="btn btn-warning" type="submit">Buscar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <p class="text-muted small mb-2">
        <i class="bi bi-list-ul"></i> @Model.Count vehículo(s) encontrado(s)
    </p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background-color: #212529; color: white;">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Modelo</th>
                        <th>Color</th>
                        <th>Placa</th>
                        <th>Cliente</th>
                        <th>Mecánico</th>
                        <th>F. Entrada</th>
                        <th>F. Salida</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-inbox" style="font-size:2rem"></i>
                                <p class="mt-2">No hay vehículos registrados</p>
                            </td>
                        </tr>
                    }
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td class="ps-3 text-muted">#@v.Id_vehiculo</td>
                            <td><span class="fw-semibold">@v.Modelo</span></td>
                            <td>@v.Color</td>
                            <td><span class="badge bg-secondary">@v.Placa</span></td>
                            <td>@v.NombreCliente</td>
                            <td>
                                @if (string.IsNullOrEmpty(v.NombreMecanico))
                                {
                                    <span class="badge bg-secondary">Sin asignar</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@v.NombreMecanico</span>
                                }
                            </td>
                            <td>@v.Fecha_Entre.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (v.Fecha_Salida.HasValue)
                                {
                                    <span class="text-success">@v.Fecha_Salida.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">En taller</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Editar" asp-route-id="@v.Id_vehiculo"
                                   class="btn btn-warning btn-sm me-1">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <a asp-action="Eliminar" asp-route-id="@v.Id_vehiculo"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('¿Desea eliminar este vehículo?')">
                                    <i class="bi bi-trash3"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>