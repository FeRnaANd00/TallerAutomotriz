@model TallerMecanico.EN.Mecanico

<div class="container mt-4">

    <h2>Eliminar Mecánico</h2>

    <div class="alert alert-danger">
        ¿Deseas eliminar este mecánico?
    </div>

    <dl class="row">

        <dt class="col-sm-2">
            Nombre
        </dt>

        <dd class="col-sm-10">
            @Model.Nombre
        </dd>

        <dt class="col-sm-2">
            Cargo
        </dt>

        <dd class="col-sm-10">
            @Model.Cargo_id
        </dd>

    </dl>

    <form method="post">

        <input type="hidden"
               asp-for="Id_mecanico" />

        <button type="submit"
                class="btn btn-danger">
            Eliminar
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Cancelar
        </a>

    </form>

</div>  