@model TallerMecanico.EN.Mecanico

@{
    ViewData["Title"] = "Agregar Mecánico";
}

<div class="container mt-4">
    <h2>Agregar Mecánico</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <span>@ViewBag.Error</span>
            <a asp-controller="Cargo" asp-action="Agregar" class="btn btn-sm btn-outline-warning ms-3">
                <i class="bi bi-plus-circle"></i> Crear Cargo
            </a>
        </div>
    }

    <form method="post" asp-action="Agregar">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input type="text" name="Nombre" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Dirección</label>
            <input type="text" name="Direccion" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input type="text" name="Telefono" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Pago por Hora</label>
            <input type="number" step="0.01" name="Pago_Hora" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Cargo</label>
            <div class="input-group">
                <select name="Cargo_id" class="form-select">
                    <option value="">-- Selecciona un cargo --</option>
                    @foreach (var item in (SelectList)ViewBag.Cargos)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
                <a asp-controller="Cargo" asp-action="Agregar"
                   asp-route-returnUrl="@Context.Request.Path"
                   class="btn btn-outline-success" title="Crear nuevo cargo">
                    <i class="bi bi-plus-fill"></i> Nuevo
                </a>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save"></i> Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
            <button type="button" class="btn btn-outline-secondary" onclick="history.back()">← Regresar</button>
        </div>
    </form>
</div>