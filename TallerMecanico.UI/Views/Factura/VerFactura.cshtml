@model TallerMecanico.EN.Factura

@{
    ViewData["Title"] = "Ver Factura";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-receipt text-success"></i> Factura #@Model.Id_factura</h2>
        <span class="badge bg-@(Model.Estado == "Pagada" ? "success" : "warning") fs-6">
            @Model.Estado
        </span>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-1"><strong>Cliente:</strong> @Model.NombreCliente</p>
                    <p class="mb-1"><strong>Fecha:</strong> @Model.Fecha.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="mb-1"><strong>Factura N°:</strong> @Model.Id_factura.ToString("D6")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead style="background-color: #212529; color: white;">
                    <tr>
                        <th class="ps-3">Descripción</th>
                        <th class="text-end pe-3">Precio</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in Model.Detalles)
                    {
                        <tr>
                            <td class="ps-3">@detalle.Descripcion</td>
                            <td class="text-end pe-3">$@detalle.Precio.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between">
                <span>Subtotal:</span>
                <span>$@Model.Subtotal.ToString("0.00")</span>
            </div>
            <div class="d-flex justify-content-between">
                <span>Impuestos:</span>
                <span>$@Model.Impuestos.ToString("0.00")</span>
            </div>
            <hr />
            <div class="d-flex justify-content-between fs-4">
                <strong>TOTAL:</strong>
                <strong class="text-success">$@Model.Total.ToString("0.00")</strong>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="button" class="btn btn-outline-secondary" onclick="history.back()">← Regresar</button>
        <button onclick="window.print()" class="btn btn-primary">
            <i class="bi bi-printer"></i> Imprimir
        </button>
    </div>
</div>