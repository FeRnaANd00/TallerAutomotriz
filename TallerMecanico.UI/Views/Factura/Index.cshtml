@model List<TallerMecanico.EN.Factura>

@{
    ViewData["Title"] = "Facturas";
}

<div class="container-fluid mt-4 px-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-receipt text-warning"></i> Facturas
            </h2>
            <small class="text-muted">Historial de facturación</small>
        </div>
    </div>

    <p class="text-muted small mb-2">
        <i class="bi bi-list-ul"></i> @Model.Count factura(s) registrada(s)
    </p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background-color: #212529; color: white;">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Subtotal</th>
                        <th>Impuestos</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-inbox" style="font-size:2rem"></i>
                                <p class="mt-2">No hay facturas registradas</p>
                            </td>
                        </tr>
                    }
                    @foreach (var f in Model)
                    {
                        <tr>
                            <td class="ps-3 text-muted">#@f.Id_factura</td>
                            <td>@f.NombreCliente</td>
                            <td>@f.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>$@f.Subtotal.ToString("0.00")</td>
                            <td>$@f.Impuestos.ToString("0.00")</td>
                            <td><strong>$@f.Total.ToString("0.00")</strong></td>
                            <td>
                                <span class="badge bg-@(f.Estado == "Pagada" ? "success" : "warning")">
                                    @f.Estado
                                </span>
                            </td>
                            <td class="text-center">
                                @if (f.Id_Hoja.HasValue)
                                {
                                    <a asp-action="VerFactura" asp-route-idHoja="@f.Id_Hoja"
                                       class="btn btn-primary btn-sm">
                                        <i class="bi bi-eye"></i> Ver
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>