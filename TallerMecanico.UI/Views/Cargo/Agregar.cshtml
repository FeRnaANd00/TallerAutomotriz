@{
    ViewData["Title"] = "Agregar Cargo";
}

<div class="container mt-4">
    <h2><i class="bi bi-briefcase text-warning"></i> Agregar Cargo</h2>

    <form method="post" asp-action="Agregar">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="mb-3">
            <label class="form-label">Nombre del Cargo</label>
            <input type="text" name="Nombre" class="form-control"
                   required maxlength="40"
                   placeholder="Ej: Mecánico General, Electricista, Jefe de Taller..." />
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save"></i> Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
            <button type="button" class="btn btn-outline-secondary" onclick="history.back()">← Regresar</button>
        </div>
    </form>
</div>